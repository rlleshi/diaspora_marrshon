# Local development environment.
# Keep real secrets in .env.local, never in git.

FIREBASE_PROJECT_ID=diaspora-zbarkon

# Preferred local Firebase Admin auth:
# Download a Firebase service-account JSON and point this at its absolute path.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/diaspora-zbarkon-firebase-adminsdk.json

# Firestore collections for development data.
FIREBASE_PLEDGES_COLLECTION=pledges_dev
FIREBASE_EMAIL_CONFIRMATIONS_COLLECTION=email_confirmations_dev
FIREBASE_CONSENT_VERSIONS_COLLECTION=consent_versions_dev
FIREBASE_RATE_LIMIT_COLLECTION=rate_limit_events_dev

# Anti-spam.
RATE_LIMIT_SALT=replace-with-a-long-random-secret
ALLOWED_FORM_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email confirmation.
RESEND_API_KEY=
EMAIL_FROM=
APP_BASE_URL=http://localhost:3000
EMAIL_CONFIRMATION_SECRET=replace-with-a-different-long-random-secret

# Vercel/deployment alternative for Firebase Admin auth:
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
